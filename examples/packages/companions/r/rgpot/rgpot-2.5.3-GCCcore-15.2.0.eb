easyblock = 'MesonNinja'

name = 'rgpot'
version = '2.5.3'

homepage = 'https://github.com/OmniPotentRPC/rgpot'
description = """Potential frontends with Cap'n Proto RPC (NWChem/CPMD clients;
engines are loaded at runtime via dlopen). Built fat: RPC server (potserv),
Eigen array backend, and nanobind Python bindings."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}
toolchainopts = {'pic': True, 'cstd': 'c++20'}

github_account = 'OmniPotentRPC'
source_urls = [GITHUB_SOURCE]
sources = [{
    'download_filename': 'v%(version)s.tar.gz',
    'filename': SOURCE_TAR_GZ,
}]
checksums = ['391c52089701c6d60201819ebad67b51518843151fb7a888d25558758a369474']

builddependencies = [
    ('binutils', '2.45'),
    ('Meson', '1.10.2'),
    ('Ninja', '1.13.2'),
    ('pkgconf', '2.5.1'),
    ('CMake', '4.2.1'),
    ('Catch2', '3.14.0'),
    ('Eigen', '5.0.0'),
    ('nanobind', '2.13.0'),
]

dependencies = [
    ('CapnProto', '1.4.0'),
    ('fmt', '12.2.0'),
    ('Python', '3.14.2'),
    ('RocksDB', '11.1.2'),
]

# Fat build: full RPC (server + clients), Eigen backend, Python bindings,
# RocksDB-backed potential cache, unit and example tests. The metatomic and
# NWChem/CPMD dlopen frontends always compile; their engines load at
# runtime. xxhash for the cache comes from the hash-pinned meson wrap.
# Off because a GCCcore recipe cannot link them: with_xtb and with_tblite
# need BLAS-backed packages (gfbf generation; a versionsuffix variant
# belongs there), with_metatomic links the torch stack, with_xtensor
# duplicates the Eigen backend, with_rust_core needs a cargo network fetch
# at build time.
configopts = '-Dpure_lib=false -Dwith_rpc=true -Dwith_eigen=true '
configopts += '-Dwith_python=true -Dwith_cache=true '
configopts += '-Dwith_tests=true -Dwith_examples=true '

runtest = 'meson'
testopts = 'test -C %(builddir)s/easybuild_obj'

sanity_check_paths = {
    'files': [
        'bin/potserv',
        'lib/librgpot.%s' % SHLIB_EXT,
        'lib/libnwchempot.a',
        'lib/libcpmdpot.a',
        'lib/libptlrpc.%s' % SHLIB_EXT,
        'lib/pkgconfig/rgpot.pc',
    ],
    'dirs': [
        'include/rgpot',
        'lib',
        'lib/python%(pyshortver)s/site-packages/rgpot',
    ],
}

sanity_check_commands = [
    "pkg-config --exists rgpot",
    "python -c 'import rgpot'",
]

modextrapaths = {'PYTHONPATH': 'lib/python%(pyshortver)s/site-packages'}

moduleclass = 'lib'
