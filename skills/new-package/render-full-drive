#!/usr/bin/env python3
"""Render full-drive.sh + hermes-full-drive.md from skill templates.

Example:
  skills/new-package/render-full-drive \\
    --work ~/tmp/eb-campaign --repo ~/Git/.../eb-stack --robot ~/.../easyconfigs \\
    --recipe work/easyconfigs/q/QMCPACK/QMCPACK-4.3.0-foss-2026.1.eb \\
    --oracle fixtures/qmcpack_foss_2026_1/easyconfigs/q/QMCPACK/QMCPACK-4.3.0-foss-2026.1.eb \\
    --stem qmcpack \\
    --recipe work/easyconfigs/e/eOn/eOn-2.16.0-foss-2026.1.eb \\
    --oracle fixtures/eon_foss_2026_1/easyconfigs/e/eOn/eOn-2.16.0-foss-2026.1.eb \\
    --stem eon \\
    --overlay fixtures/eon_foss_2026_1/easyconfigs

Then:
  bash $WORK/residuals/full-drive.sh
  # or herdr agent with -q "$(cat $WORK/residuals/hermes-full-drive.md)"
"""
from __future__ import annotations

import argparse
import re
import stat
import sys
from pathlib import Path


def skill_root() -> Path:
    return Path(__file__).resolve().parent


def load_tmpl(name: str) -> str:
    return (skill_root() / "templates" / name).read_text(encoding="utf-8")


def render(tmpl: str, mapping: dict[str, str]) -> str:
    out = tmpl
    for k, v in mapping.items():
        out = out.replace(f"@@{k}@@", v)
    bad = re.findall(r"@@([A-Z0-9_]+)@@", out)
    if bad:
        raise SystemExit(f"unreplaced template keys: {sorted(set(bad))}")
    return out


def esc_sq(s: str) -> str:
    return s.replace("'", "'\"'\"'")


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("--work", required=True, type=Path)
    ap.add_argument("--repo", required=True, type=Path)
    ap.add_argument("--robot", required=True, type=Path)
    ap.add_argument("--recipe", action="append", default=[], metavar="PATH")
    ap.add_argument("--oracle", action="append", default=[], metavar="PATH",
                    help="Oracle for recipes in order (pad empty if fewer than recipes)")
    ap.add_argument("--stem", action="append", default=[], metavar="NAME",
                    help="robot-*.log stem for recipes in order")
    ap.add_argument("--overlay", type=Path, default=None,
                    help="Companion easyconfigs tree rsynced into WORK/easyconfigs")
    ap.add_argument("--eb", type=Path, default=None)
    ap.add_argument("--out-dir", type=Path, default=None)
    ap.add_argument("--sourcepath", type=Path, default=None)
    ap.add_argument("--tmpdir", type=Path, default=None)
    ap.add_argument("--installpath", type=Path, default=None)
    ap.add_argument("--extra-path", default="")
    ap.add_argument("--skill-path", default="skills/new-package/SKILL.md")
    ap.add_argument("--dry-run", action="store_true")
    args = ap.parse_args()

    if not args.recipe:
        ap.error("at least one --recipe is required")

    n = len(args.recipe)
    oracles = list(args.oracle) + [""] * max(0, n - len(args.oracle))
    stems = list(args.stem) + [""] * max(0, n - len(args.stem))
    oracles, stems = oracles[:n], stems[:n]

    work = args.work.expanduser().resolve()
    repo = args.repo.expanduser().resolve()
    robot = args.robot.expanduser().resolve()
    out_dir = (args.out_dir or (work / "residuals")).expanduser().resolve()
    eb = (args.eb or (repo / "target" / "release" / "eb-stack")).expanduser().resolve()
    home = Path.home()
    sourcepath = (args.sourcepath or (home / "tmp" / "eb-sources")).expanduser().resolve()
    tmpdir = (args.tmpdir or (home / "tmp" / "eb-tmp")).expanduser().resolve()
    installpath = (args.installpath or (home / "tmp" / "eb-install")).expanduser().resolve()
    overlay = str(args.overlay.expanduser().resolve()) if args.overlay else ""

    bash_lines = []
    bullets = []
    for r, o, s in zip(args.recipe, oracles, stems):
        rp = Path(r).expanduser()
        r_s = str(rp)
        o_s = str(Path(o).expanduser()) if o else ""
        if not s:
            s = Path(r_s).name
            if s.endswith(".eb"):
                s = s[: -3]
        bash_lines.append(f"  '{esc_sq(r_s)}|{esc_sq(o_s)}|{esc_sq(s)}'")
        if o_s:
            bullets.append(f"- `{r_s}` (oracle: `{o_s}`, stem: `{s}`)")
        else:
            bullets.append(f"- `{r_s}` (stem: `{s}`)")

    mapping = {
        "EXTRA_PATH": args.extra_path or str(eb.parent),
        "EASYBUILD_SOURCEPATH": str(sourcepath),
        "EASYBUILD_TMPDIR": str(tmpdir),
        "EASYBUILD_INSTALLPATH": str(installpath),
        "WORK": str(work),
        "REPO": str(repo),
        "ROBOT": str(robot),
        "EB": str(eb),
        "OVERLAY_DIR": overlay,
        "RECIPES_BASH_ARRAY": "\n".join(bash_lines),
        "SKILL_PATH": args.skill_path,
        "FULL_DRIVE_SCRIPT": str(out_dir / "full-drive.sh"),
        "RECIPES_BULLETS": "\n".join(bullets),
    }

    sh = render(load_tmpl("full-drive.sh.tmpl"), mapping)
    md = render(load_tmpl("hermes-full-drive.md.tmpl"), mapping)
    sh_path = out_dir / "full-drive.sh"
    md_path = out_dir / "hermes-full-drive.md"

    if args.dry_run:
        print(f"would write {sh_path}")
        print(f"would write {md_path}")
        print(f"recipes={n}")
        return 0

    out_dir.mkdir(parents=True, exist_ok=True)
    sh_path.write_text(sh, encoding="utf-8")
    mode = sh_path.stat().st_mode
    sh_path.chmod(mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
    md_path.write_text(md, encoding="utf-8")
    print(f"wrote {sh_path}")
    print(f"wrote {md_path}")
    print(f"recipes={n}")
    print(f"next: bash {sh_path}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
