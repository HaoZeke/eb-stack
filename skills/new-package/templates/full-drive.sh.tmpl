#!/usr/bin/env bash
# Generated by skills/new-package/render-full-drive — re-render instead of hand-editing.
# Gates on host; *builds* via @@BUILD_BACKEND@@ (default: podman Rocky 9).
set -euo pipefail

export PATH="${HOME}/.venvs/easybuild/bin:@@EB_STACK_DIR@@:${HOME}/.local/bin:${PATH}"
export LMOD_CMD="${LMOD_CMD:-${HOME}/.local/lmod/lmod/libexec/lmod}"
export FPATH="${FPATH:-}"
# shellcheck disable=SC1090
source "${HOME}/.local/lmod/lmod/init/bash" 2>/dev/null || true

export EASYBUILD_MODULES_TOOL="${EASYBUILD_MODULES_TOOL:-Lmod}"
export EASYBUILD_SOURCEPATH="@@EASYBUILD_SOURCEPATH@@"
export EASYBUILD_TMPDIR="@@EASYBUILD_TMPDIR@@"
export EASYBUILD_INSTALLPATH="@@EASYBUILD_INSTALLPATH@@"
export EASYBUILD_BUILDPATH="@@EASYBUILD_BUILDPATH@@"

WORK="@@WORK@@"
REPO="@@REPO@@"
ROBOT="@@ROBOT@@"
EB_STACK="@@EB_STACK@@"
EASYBUILD_EB="@@EASYBUILD_EB@@"
OVERLAY_DIR="@@OVERLAY_DIR@@"
BUILD_BACKEND="@@BUILD_BACKEND@@"   # podman-rocky9 | host
EB_IN_PODMAN="${REPO}/skills/new-package/container/rocky9/eb-in-podman"
PODMAN_IMAGE="${EB_PODMAN_IMAGE:-eb-stack-rocky9}"

if [[ ! -x "${EB_STACK}" ]]; then
  echo "ERROR: eb-stack binary missing at ${EB_STACK}" >&2
  exit 127
fi
if [[ ! -x "${EASYBUILD_EB}" ]]; then
  EASYBUILD_EB="$(command -v eb || true)"
fi
if [[ -n "${EASYBUILD_EB}" ]]; then
  eb_help="$("${EASYBUILD_EB}" --help 2>&1 | head -3 || true)"
  if echo "${eb_help}" | grep -q 'eb-stack'; then
    echo "ERROR: EASYBUILD_EB resolves to eb-stack (${EASYBUILD_EB})" >&2
    exit 127
  fi
fi

mkdir -p "${EASYBUILD_SOURCEPATH}" "${EASYBUILD_TMPDIR}" "${EASYBUILD_INSTALLPATH}" \
  "${EASYBUILD_BUILDPATH}" "${WORK}/logs" "${WORK}/residuals" "${WORK}/easyconfigs"

# Host-only OS-dep name probe opts (unused inside Rocky container)
eb_osdep_opts=()
os_id=""
if [[ -r /etc/os-release ]]; then
  # shellcheck disable=SC1091
  . /etc/os-release
  os_id="${ID:-}"
fi
if [[ "${BUILD_BACKEND}" == "host" ]]; then
  if [[ "${EB_IGNORE_OSDEPS:-}" == "1" ]]; then
    eb_osdep_opts+=(--ignore-osdeps)
  fi
fi

RECIPES=(
@@RECIPES_BASH_ARRAY@@
)

if [[ -n "${OVERLAY_DIR}" && -d "${OVERLAY_DIR}" ]]; then
  echo "===== companion overlay from ${OVERLAY_DIR} ====="
  rsync -a "${OVERLAY_DIR}/" "${WORK}/easyconfigs/"
fi

# Optional host-OS overlays only when building on host
if [[ "${BUILD_BACKEND}" == "host" ]]; then
  HOST_OVERLAY="${REPO}/skills/new-package/overlays/${os_id:-unknown}"
  if [[ -d "${HOST_OVERLAY}" ]]; then
    echo "===== host-OS overlay ${HOST_OVERLAY} ====="
    rsync -a --exclude stubs/ "${HOST_OVERLAY}/" "${WORK}/easyconfigs/"
  fi
  STUB_INC="${REPO}/skills/new-package/overlays/${os_id:-unknown}/stubs/include"
  if [[ -d "${STUB_INC}" ]]; then
    export CPATH="${STUB_INC}${CPATH:+:$CPATH}"
    export C_INCLUDE_PATH="${STUB_INC}${C_INCLUDE_PATH:+:$C_INCLUDE_PATH}"
    export CPLUS_INCLUDE_PATH="${STUB_INC}${CPLUS_INCLUDE_PATH:+:$CPLUS_INCLUDE_PATH}"
    echo "===== host stubs CPATH=${STUB_INC} ====="
  fi
fi

# eb invocation for dry-run / robot
run_eb() {
  # usage: run_eb [eb args...]
  if [[ "${BUILD_BACKEND}" == "podman-rocky9" ]]; then
    if [[ ! -x "${EB_IN_PODMAN}" ]]; then
      echo "ERROR: missing ${EB_IN_PODMAN}" >&2
      exit 127
    fi
    "${EB_IN_PODMAN}" \
      --work "${WORK}" \
      --robot "${ROBOT}" \
      --sources "${EASYBUILD_SOURCEPATH}" \
      --install "${EASYBUILD_INSTALLPATH}" \
      --tmpdir "${EASYBUILD_TMPDIR}" \
      --build "${EASYBUILD_BUILDPATH}" \
      --image "${PODMAN_IMAGE}" \
      -- \
      --modules-tool=Lmod \
      "$@"
  else
    if [[ -z "${EASYBUILD_EB}" || ! -x "${EASYBUILD_EB}" ]]; then
      echo "ERROR: host EasyBuild eb not found" >&2
      exit 127
    fi
    "${EASYBUILD_EB}" --modules-tool=Lmod "${eb_osdep_opts[@]}" "$@"
  fi
}

# Gates: style/check-contrib/check-recipe on host when possible; robot always via backend.
gate() {
  local f="$1"
  echo "===== format-style $(basename "$f") ====="
  "${EB_STACK}" format-style "$f" || true
  "${EB_STACK}" check-style "$f"
  sed -i 's/[[:space:]]*$//' "$f"
  echo "===== check-contrib ====="
  if [[ -n "${EASYBUILD_EB}" && -x "${EASYBUILD_EB}" ]]; then
    "${EASYBUILD_EB}" --modules-tool=Lmod --check-contrib "$f"
  else
    run_eb --check-contrib "$f"
  fi
  echo "===== check-recipe ====="
  "${EB_STACK}" check-recipe --recipe "$f" --easyconfigs "${ROBOT}" --easyconfigs "${WORK}/easyconfigs"
  echo "===== eb -Dr (backend=${BUILD_BACKEND}) ====="
  run_eb -Dr --robot "${WORK}/easyconfigs:${ROBOT}" "$f"
}

declare -a STEMS=()
declare -a PATHS=()
declare -a RCS=()

for entry in "${RECIPES[@]}"; do
  IFS='|' read -r rpath oracle stem <<<"${entry}"
  if [[ "${rpath}" != /* ]]; then
    rpath="${WORK}/${rpath}"
  fi
  if [[ -n "${oracle}" ]]; then
    if [[ "${oracle}" != /* ]]; then
      oracle="${REPO}/${oracle}"
    fi
    echo "===== oracle copy $(basename "$oracle") -> $(basename "$rpath") ====="
    mkdir -p "$(dirname "$rpath")"
    cp -a "${oracle}" "${rpath}"
  fi
  if [[ -z "${stem}" ]]; then
    stem="$(basename "${rpath}" .eb)"
  fi
  gate "${rpath}"
  PATHS+=("${rpath}")
  STEMS+=("${stem}")
done

overall=0
for i in "${!PATHS[@]}"; do
  rpath="${PATHS[$i]}"
  stem="${STEMS[$i]}"
  log="${WORK}/logs/robot-${stem}.log"
  echo "===== ROBOT ${stem} backend=${BUILD_BACKEND} ====="
  set +e
  run_eb --robot "${WORK}/easyconfigs:${ROBOT}" "${rpath}" 2>&1 | tee "${log}"
  rc=${PIPESTATUS[0]}
  set -e
  echo "robot_exit_${stem}=${rc}"
  RCS+=("${rc}")
  if [[ "${rc}" -ne 0 ]]; then
    overall=1
  fi
done

{
  echo "# session-log full-drive (rendered)"
  echo
  echo "- build_backend: ${BUILD_BACKEND}"
  echo "- podman_image: ${PODMAN_IMAGE}"
  echo "- host_os_id: ${os_id:-unknown}"
  echo "- easybuild_eb: ${EASYBUILD_EB:-container}"
  echo "- eb_stack: ${EB_STACK}"
  echo
  for i in "${!PATHS[@]}"; do
    rpath="${PATHS[$i]}"
    stem="${STEMS[$i]}"
    rc="${RCS[$i]}"
    echo "## ${stem}"
    echo "- recipe: \`${rpath}\`"
    echo "- resolves: yes (check-recipe + eb -Dr; re-verify after later edits)"
    if [[ "${rc}" -eq 0 ]]; then
      echo "- builds: yes (eb --robot exit 0; log \`logs/robot-${stem}.log\`)"
    else
      echo "- builds: no (eb --robot exit ${rc}; log \`logs/robot-${stem}.log\`)"
    fi
    echo "- binary-verified: no"
    echo
  done
  if [[ "${overall}" -eq 0 ]]; then
    echo "DONE_FULL_DRIVE"
  else
    echo "DONE_PARTIAL overall=${overall}"
  fi
} | tee "${WORK}/residuals/session-log.md"

exit "${overall}"
