#!/usr/bin/env bash
# Generated by skills/new-package/render-full-drive — re-render instead of hand-editing.
# Mechanical gates + eb --robot (*builds*) for listed recipes (new-package skill §7).
set -euo pipefail

export PATH="@@EXTRA_PATH@@:${HOME}/.venvs/easybuild/bin:${HOME}/.local/bin:${PATH}"
export LMOD_CMD="${LMOD_CMD:-${HOME}/.local/lmod/lmod/libexec/lmod}"
export FPATH="${FPATH:-}"
# shellcheck disable=SC1090
source "${HOME}/.local/lmod/lmod/init/bash" 2>/dev/null || true

export EASYBUILD_MODULES_TOOL="${EASYBUILD_MODULES_TOOL:-Lmod}"
export EASYBUILD_SOURCEPATH="@@EASYBUILD_SOURCEPATH@@"
export EASYBUILD_TMPDIR="@@EASYBUILD_TMPDIR@@"
export EASYBUILD_INSTALLPATH="@@EASYBUILD_INSTALLPATH@@"

WORK="@@WORK@@"
REPO="@@REPO@@"
ROBOT="@@ROBOT@@"
EB="@@EB@@"
OVERLAY_DIR="@@OVERLAY_DIR@@"

mkdir -p "${EASYBUILD_SOURCEPATH}" "${EASYBUILD_TMPDIR}" "${EASYBUILD_INSTALLPATH}" \
  "${WORK}/logs" "${WORK}/residuals"

# --- OS dependency policy (teach the campaign, not residual judgment) ---
# EasyBuild checks Debian/RHEL *package names* (libibverbs-dev, rdma-core-devel).
# On Arch the package is `rdma-core` (libs + headers); EB never matches those names.
# Policy: if InfiniBand/verbs headers are on disk, pass --ignore-osdeps for robot.
# Force with EB_IGNORE_OSDEPS=1; refuse ignore with EB_IGNORE_OSDEPS=0 even on Arch.
eb_osdep_opts=()
os_id=""
if [[ -r /etc/os-release ]]; then
  # shellcheck disable=SC1091
  . /etc/os-release
  os_id="${ID:-}"
fi
verbs_h="/usr/include/infiniband/verbs.h"
if [[ "${EB_IGNORE_OSDEPS:-}" == "1" ]]; then
  eb_osdep_opts+=(--ignore-osdeps)
  echo "===== OSDEPS: EB_IGNORE_OSDEPS=1 → --ignore-osdeps ====="
elif [[ "${EB_IGNORE_OSDEPS:-}" == "0" ]]; then
  echo "===== OSDEPS: EB_IGNORE_OSDEPS=0 → strict package-name checks ====="
elif [[ "${os_id}" == "arch" ]]; then
  if [[ -f "${verbs_h}" ]]; then
    eb_osdep_opts+=(--ignore-osdeps)
    echo "===== OSDEPS: Arch + ${verbs_h} present → --ignore-osdeps ====="
    echo "===== (pacman: rdma-core; EB only knows Debian/RHEL package names) ====="
  else
    echo "===== OSDEPS: Arch but ${verbs_h} MISSING — install: sudo pacman -S --needed rdma-core =====" >&2
    echo "===== refusing to ignore OS deps without headers =====" >&2
    exit 2
  fi
else
  echo "===== OSDEPS: os_id=${os_id:-unknown} — default EB package-name checks ====="
fi

# Each entry: RECIPE_PATH|ORACLE_PATH_OR_EMPTY|LOG_STEM
RECIPES=(
@@RECIPES_BASH_ARRAY@@
)

if [[ -n "${OVERLAY_DIR}" && -d "${OVERLAY_DIR}" ]]; then
  echo "===== companion overlay from ${OVERLAY_DIR} ====="
  rsync -a "${OVERLAY_DIR}/" "${WORK}/easyconfigs/"
fi

gate() {
  local f="$1"
  echo "===== format-style $(basename "$f") ====="
  if [[ -x "${EB}" ]] || command -v "${EB}" >/dev/null 2>&1; then
    "${EB}" format-style "$f" || true
    "${EB}" check-style "$f"
  else
    echo "WARN: eb-stack binary missing at ${EB}; skip format/check-style" >&2
  fi
  sed -i 's/[[:space:]]*$//' "$f"
  echo "===== check-contrib ====="
  eb --modules-tool=Lmod --check-contrib "$f"
  echo "===== check-recipe ====="
  "${EB}" check-recipe --recipe "$f" --easyconfigs "${ROBOT}" --easyconfigs "${WORK}/easyconfigs"
  echo "===== eb -Dr ====="
  # dry-run also evaluates OS deps for some EB versions
  eb --modules-tool=Lmod "${eb_osdep_opts[@]}" -Dr --robot "${WORK}/easyconfigs:${ROBOT}" "$f"
}

declare -a STEMS=()
declare -a PATHS=()
declare -a RCS=()

for entry in "${RECIPES[@]}"; do
  IFS='|' read -r rpath oracle stem <<<"${entry}"
  if [[ "${rpath}" != /* ]]; then
    rpath="${WORK}/${rpath}"
  fi
  if [[ -n "${oracle}" ]]; then
    if [[ "${oracle}" != /* ]]; then
      oracle="${REPO}/${oracle}"
    fi
    echo "===== oracle copy $(basename "$oracle") -> $(basename "$rpath") ====="
    mkdir -p "$(dirname "$rpath")"
    cp -a "${oracle}" "${rpath}"
  fi
  if [[ -z "${stem}" ]]; then
    stem="$(basename "${rpath}" .eb)"
  fi
  gate "${rpath}"
  PATHS+=("${rpath}")
  STEMS+=("${stem}")
done

overall=0
for i in "${!PATHS[@]}"; do
  rpath="${PATHS[$i]}"
  stem="${STEMS[$i]}"
  log="${WORK}/logs/robot-${stem}.log"
  echo "===== ROBOT ${stem} ====="
  set +e
  eb --modules-tool=Lmod "${eb_osdep_opts[@]}" --robot "${WORK}/easyconfigs:${ROBOT}" "${rpath}" 2>&1 | tee "${log}"
  rc=${PIPESTATUS[0]}
  set -e
  echo "robot_exit_${stem}=${rc}"
  RCS+=("${rc}")
  if [[ "${rc}" -ne 0 ]]; then
    overall=1
  fi
done

{
  echo "# session-log full-drive (rendered)"
  echo
  echo "- os_id: ${os_id:-unknown}"
  echo "- eb_osdep_opts: ${eb_osdep_opts[*]:-(none)}"
  echo
  for i in "${!PATHS[@]}"; do
    rpath="${PATHS[$i]}"
    stem="${STEMS[$i]}"
    rc="${RCS[$i]}"
    echo "## ${stem}"
    echo "- recipe: \`${rpath}\`"
    echo "- resolves: yes (check-recipe + eb -Dr before robot; re-verify after later edits)"
    if [[ "${rc}" -eq 0 ]]; then
      echo "- builds: yes (eb --robot exit 0; log \`logs/robot-${stem}.log\`)"
    else
      echo "- builds: no (eb --robot exit ${rc}; log \`logs/robot-${stem}.log\`)"
    fi
    echo "- binary-verified: no"
    echo
  done
  if [[ "${overall}" -eq 0 ]]; then
    echo "DONE_FULL_DRIVE"
  else
    echo "DONE_PARTIAL overall=${overall}"
  fi
} | tee "${WORK}/residuals/session-log.md"

exit "${overall}"
