#!/usr/bin/env bash
# Generated by skills/new-package/render-full-drive — re-render instead of hand-editing.
# Mechanical gates + eb --robot (*builds*) for listed recipes (new-package skill §7).
set -euo pipefail

# PATH: EasyBuild's `eb` MUST come before any eb-stack dir that may ship a
# symlink named `eb` → eb-stack (that collision made --robot hit clap).
export PATH="${HOME}/.venvs/easybuild/bin:@@EB_STACK_DIR@@:${HOME}/.local/bin:${PATH}"
export LMOD_CMD="${LMOD_CMD:-${HOME}/.local/lmod/lmod/libexec/lmod}"
export FPATH="${FPATH:-}"
# shellcheck disable=SC1090
source "${HOME}/.local/lmod/lmod/init/bash" 2>/dev/null || true

export EASYBUILD_MODULES_TOOL="${EASYBUILD_MODULES_TOOL:-Lmod}"
export EASYBUILD_SOURCEPATH="@@EASYBUILD_SOURCEPATH@@"
export EASYBUILD_TMPDIR="@@EASYBUILD_TMPDIR@@"
export EASYBUILD_INSTALLPATH="@@EASYBUILD_INSTALLPATH@@"

WORK="@@WORK@@"
REPO="@@REPO@@"
ROBOT="@@ROBOT@@"
# Distinct binaries — never shadow EasyBuild `eb` with eb-stack.
EB_STACK="@@EB_STACK@@"
EASYBUILD_EB="@@EASYBUILD_EB@@"
OVERLAY_DIR="@@OVERLAY_DIR@@"

if [[ ! -x "${EASYBUILD_EB}" ]]; then
  # fall back to PATH after venv prepend
  EASYBUILD_EB="$(command -v eb)"
fi
if [[ ! -x "${EB_STACK}" ]]; then
  echo "ERROR: eb-stack binary missing at ${EB_STACK}" >&2
  exit 127
fi
# Guard: `eb` must be EasyBuild, not eb-stack
eb_help="$("${EASYBUILD_EB}" --help 2>&1 | head -3 || true)"
if echo "${eb_help}" | grep -q 'eb-stack'; then
  echo "ERROR: EASYBUILD_EB resolves to eb-stack (${EASYBUILD_EB}); fix PATH/symlink" >&2
  exit 127
fi

mkdir -p "${EASYBUILD_SOURCEPATH}" "${EASYBUILD_TMPDIR}" "${EASYBUILD_INSTALLPATH}" \
  "${WORK}/logs" "${WORK}/residuals"

# --- OS dependency policy (Arch vs Debian/RHEL package names) ---
eb_osdep_opts=()
os_id=""
if [[ -r /etc/os-release ]]; then
  # shellcheck disable=SC1091
  . /etc/os-release
  os_id="${ID:-}"
fi
verbs_h="/usr/include/infiniband/verbs.h"
if [[ "${EB_IGNORE_OSDEPS:-}" == "1" ]]; then
  eb_osdep_opts+=(--ignore-osdeps)
  echo "===== OSDEPS: EB_IGNORE_OSDEPS=1 → --ignore-osdeps ====="
elif [[ "${EB_IGNORE_OSDEPS:-}" == "0" ]]; then
  echo "===== OSDEPS: EB_IGNORE_OSDEPS=0 → strict package-name checks ====="
elif [[ "${os_id}" == "arch" ]]; then
  if [[ -f "${verbs_h}" ]]; then
    eb_osdep_opts+=(--ignore-osdeps)
    echo "===== OSDEPS: Arch + ${verbs_h} present → --ignore-osdeps ====="
  else
    echo "===== OSDEPS: Arch but ${verbs_h} MISSING — install: sudo pacman -S --needed rdma-core =====" >&2
    exit 2
  fi
else
  echo "===== OSDEPS: os_id=${os_id:-unknown} — default EB package-name checks ====="
fi

RECIPES=(
@@RECIPES_BASH_ARRAY@@
)

# Site Arch overlays (binutils --disable-gprofng for host GCC 16, etc.)
ARCH_OVERLAY="${REPO}/skills/new-package/overlays/arch"
if [[ "${os_id}" == "arch" && -d "${ARCH_OVERLAY}" ]]; then
  echo "===== Arch host overlays from ${ARCH_OVERLAY} ====="
  rsync -a "${ARCH_OVERLAY}/" "${WORK}/easyconfigs/"
fi

if [[ -n "${OVERLAY_DIR}" && -d "${OVERLAY_DIR}" ]]; then
  echo "===== companion overlay from ${OVERLAY_DIR} ====="
  rsync -a "${OVERLAY_DIR}/" "${WORK}/easyconfigs/"
fi

gate() {
  local f="$1"
  echo "===== format-style $(basename "$f") ====="
  "${EB_STACK}" format-style "$f" || true
  "${EB_STACK}" check-style "$f"
  sed -i 's/[[:space:]]*$//' "$f"
  echo "===== check-contrib ====="
  "${EASYBUILD_EB}" --modules-tool=Lmod --check-contrib "$f"
  echo "===== check-recipe ====="
  "${EB_STACK}" check-recipe --recipe "$f" --easyconfigs "${ROBOT}" --easyconfigs "${WORK}/easyconfigs"
  echo "===== eb -Dr ====="
  "${EASYBUILD_EB}" --modules-tool=Lmod "${eb_osdep_opts[@]}" -Dr --robot "${WORK}/easyconfigs:${ROBOT}" "$f"
}

declare -a STEMS=()
declare -a PATHS=()
declare -a RCS=()

for entry in "${RECIPES[@]}"; do
  IFS='|' read -r rpath oracle stem <<<"${entry}"
  if [[ "${rpath}" != /* ]]; then
    rpath="${WORK}/${rpath}"
  fi
  if [[ -n "${oracle}" ]]; then
    if [[ "${oracle}" != /* ]]; then
      oracle="${REPO}/${oracle}"
    fi
    echo "===== oracle copy $(basename "$oracle") -> $(basename "$rpath") ====="
    mkdir -p "$(dirname "$rpath")"
    cp -a "${oracle}" "${rpath}"
  fi
  if [[ -z "${stem}" ]]; then
    stem="$(basename "${rpath}" .eb)"
  fi
  gate "${rpath}"
  PATHS+=("${rpath}")
  STEMS+=("${stem}")
done

overall=0
for i in "${!PATHS[@]}"; do
  rpath="${PATHS[$i]}"
  stem="${STEMS[$i]}"
  log="${WORK}/logs/robot-${stem}.log"
  echo "===== ROBOT ${stem} ====="
  set +e
  "${EASYBUILD_EB}" --modules-tool=Lmod "${eb_osdep_opts[@]}" --robot "${WORK}/easyconfigs:${ROBOT}" "${rpath}" 2>&1 | tee "${log}"
  rc=${PIPESTATUS[0]}
  set -e
  echo "robot_exit_${stem}=${rc}"
  RCS+=("${rc}")
  if [[ "${rc}" -ne 0 ]]; then
    overall=1
  fi
done

{
  echo "# session-log full-drive (rendered)"
  echo
  echo "- os_id: ${os_id:-unknown}"
  echo "- eb_osdep_opts: ${eb_osdep_opts[*]:-(none)}"
  echo "- easybuild_eb: ${EASYBUILD_EB}"
  echo "- eb_stack: ${EB_STACK}"
  echo
  for i in "${!PATHS[@]}"; do
    rpath="${PATHS[$i]}"
    stem="${STEMS[$i]}"
    rc="${RCS[$i]}"
    echo "## ${stem}"
    echo "- recipe: \`${rpath}\`"
    echo "- resolves: yes (check-recipe + eb -Dr before robot; re-verify after later edits)"
    if [[ "${rc}" -eq 0 ]]; then
      echo "- builds: yes (eb --robot exit 0; log \`logs/robot-${stem}.log\`)"
    else
      echo "- builds: no (eb --robot exit ${rc}; log \`logs/robot-${stem}.log\`)"
    fi
    echo "- binary-verified: no"
    echo
  done
  if [[ "${overall}" -eq 0 ]]; then
    echo "DONE_FULL_DRIVE"
  else
    echo "DONE_PARTIAL overall=${overall}"
  fi
} | tee "${WORK}/residuals/session-log.md"

exit "${overall}"
