# TorchScript C++ bindings for metatensor (libmetatensor_torch).
easyblock = 'CMakeNinja'

name = 'metatensor-torch'
version = '0.10.0'

homepage = 'https://docs.metatensor.org/'
description = """TorchScript C++ bindings for metatensor (libmetatensor_torch).
Required by metatomic-torch and eOn metatomic potentials."""

toolchain = {'name': 'foss', 'version': '2026.1'}
toolchainopts = {'pic': True, 'openmp': True}

source_urls = ['https://github.com/metatensor/metatensor/releases/download/metatensor-torch-v%(version)s/']
sources = ['metatensor-torch-cxx-%(version)s.tar.gz']
checksums = ['a0a25e061ae4fbf2a563e9fcceed68ac79b4d857e4c9803a1614d301dc3fdfcd']

builddependencies = [
    ('CMake', '4.2.1'),
    ('pkgconf', '2.5.1'),
    ('Ninja', '1.13.2'),
]

dependencies = [
    ('Python', '3.14.2'),
    # foss-2024a PyTorch layout is python3.12 (not this recipe's Python)
    ('PyTorch', '2.9.1', '', ('foss', '2024a')),
    ('metatensor', '0.2.2', '', ('GCCcore', '15.2.0')),
]

preconfigopts = (
    ("export CMAKE_PREFIX_PATH=$EBROOTPYTORCH/lib/python3.12/site-packages/torch:$EBROOTMETATENSOR${CMAKE_PREFIX_PATH:"
     + "+:$CMAKE_PREFIX_PATH} && ")
)
configopts = (
    '-DBUILD_SHARED_LIBS=ON -DCMAKE_BUILD_TYPE=Release '
    '-DTorch_DIR=$EBROOTPYTORCH/lib/python3.12/site-packages/torch/share/cmake/Torch '
)

sanity_check_paths = {
    'files': ['lib/libmetatensor_torch.%s' % SHLIB_EXT],
    'dirs': ['include', 'lib', 'lib/cmake'],
}

moduleclass = 'lib'
